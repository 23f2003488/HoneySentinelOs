}

.launch-button {
  width: 100%;
  background: linear-gradient(135deg, var(--accent), #a855f7);
  color: #fff;
  border: none;
  padding: 16px;
  border-radius: var(--r-sm);
  font-family: inherit;
  font-size: 16px;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  transition: opacity 0.15s, transform 0.1s;
}
.launch-button:hover:not(:disabled) { opacity: 0.9; transform: translateY(-1px); }
.launch-button:active:not(:disabled) { transform: translateY(0); }
.launch-button:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }
.btn-spinner {
  width: 16px; height: 16px;
  border: 2px solid rgba(255,255,255,0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ── App page ──────────────────────────────────────────────────────── */
.app-page { display: flex; flex-direction: column; height: 100vh; background: var(--bg); }

.app-header {
  display: flex;
  align-items: center;
  padding: 0 28px;
  height: 58px;
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
  gap: 16px;
  position: sticky;
  top: 0;
  z-index: 10;
}
.app-header-left { display: flex; align-items: center; gap: 10px; }
.header-hex {
  font-size: 20px;
  background: linear-gradient(135deg, var(--accent), #a855f7);
  -webkit-background-clip: text;
   background-clip: text;
  -webkit-text-fill-color: transparent;
}
.header-title { font-size: 16px; font-weight: 700; color: var(--text); letter-spacing: -0.2px; }
.app-header-center { flex: 1; display: flex; align-items: center; justify-content: center; gap: 8px; }
.conn-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.conn-dot.green { background: var(--green); box-shadow: 0 0 6px var(--green); animation: glow 2s ease-in-out infinite; }
.conn-dot.gray  { background: var(--text3); }
@keyframes glow { 0%,100%{opacity:1} 50%{opacity:0.5} }
.conn-label { font-size: 13px; color: var(--text2); }
.header-new {
  background: var(--bg3);
  border: 1px solid var(--border2);
  color: var(--text2);
  padding: 7px 16px;
  border-radius: var(--r-sm);
  font-family: inherit;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.15s;
}
.header-new:hover { border-color: var(--accent); color: var(--text); }

/* ── Stats strip ───────────────────────────────────────────────────── */
.stats-strip {
  display: flex;
  align-items: center;
  padding: 0 28px;
  height: 48px;
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
  gap: 20px;
}
.stat-item { display: flex; align-items: center; gap: 8px; }
.stat-num { font-size: 18px; font-weight: 700; color: var(--text); line-height: 1; }
.stat-lbl { font-size: 12px; color: var(--text3); }
.stat-sep { width: 1px; height: 20px; background: var(--border); }
.stat-session { font-size: 13px; font-family: monospace; color: var(--text3) !important; }

/* ── Main scroll ───────────────────────────────────────────────────── */
.main-scroll { flex: 1; overflow-y: auto; padding: 32px 24px; }
.content-col { max-width: 760px; margin: 0 auto; display: flex; flex-direction: column; gap: 16px; }

/* ── Waiting start ─────────────────────────────────────────────────── */
.waiting-start {
  display: flex;
  align-items: center;
  gap: 12px;
  color: var(--text3);
  font-size: 14px;
  padding: 24px 0;
}
.waiting-spinner {
  width: 18px; height: 18px;
  border: 2px solid var(--border2);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

/* ── Agent card ────────────────────────────────────────────────────── */
.agent-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--r);
  overflow: hidden;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.agent-card.running {
  border-color: var(--accent);
  box-shadow: 0 0 0 2px rgba(108,99,255,0.15);
}
.agent-card.waiting {
  border-color: var(--gold);
  box-shadow: 0 0 0 2px rgba(245,196,0,0.15);
}
.agent-card.done   { border-color: var(--border); }
.agent-card.failed { border-color: var(--red); }

.agent-card-header {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 16px 18px;
  cursor: pointer;
  user-select: none;
  transition: background 0.1s;
}
.agent-card-header:hover { background: rgba(255,255,255,0.02); }

.agent-emoji { font-size: 22px; flex-shrink: 0; line-height: 1; }
.agent-card-left { display: flex; align-items: center; gap: 12px; flex: 1; min-width: 0; }
.agent-card-name {
  font-size: 16px;
  font-weight: 600;
  color: var(--text);
  display: flex;
  align-items: center;
  gap: 8px;
}
.agent-card-summary {
  font-size: 13px;
  color: var(--text2);
  margin-top: 2px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.agent-card-right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
.status-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.status-dot.running { background: var(--accent); animation: glow 1.5s ease-in-out infinite; }
.status-dot.waiting { background: var(--gold); animation: glow 1.5s ease-in-out infinite; }
.status-dot.done    { background: var(--green); }
.status-dot.failed  { background: var(--red); }
.status-dot.idle    { background: var(--text3); }
.status-label { font-size: 13px; color: var(--text2); }
.expand-btn { font-size: 11px; color: var(--text3); padding: 4px; }

/* Typing dots */
.typing-indicator { display: flex; gap: 3px; align-items: center; margin-left: 6px; }
.typing-indicator span {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--accent);
  animation: typeBounce 1.2s ease-in-out infinite;
}
.typing-indicator span:nth-child(2) { animation-delay: 0.15s; }
.typing-indicator span:nth-child(3) { animation-delay: 0.3s; }
@keyframes typeBounce {
  0%,80%,100% { transform: translateY(0); opacity:0.4; }
  40% { transform: translateY(-5px); opacity:1; }
}

/* Progress bar */
.progress-bar { height: 2px; background: var(--border); overflow: hidden; }
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent), #a855f7);
  transition: width 0.4s ease;
}

/* Card body */
.agent-card-body {
  padding: 16px 18px 18px;
  display: flex;
  flex-direction: column;
  gap: 14px;
  border-top: 1px solid var(--border);
}
.agent-desc { font-size: 13px; color: var(--text3); padding-bottom: 4px; }

/* Steps trail */
.steps-trail { display: flex; flex-direction: column; }
.step-row { display: flex; gap: 0; align-items: stretch; }
.step-left { display: flex; flex-direction: column; align-items: center; width: 32px; flex-shrink: 0; }
.step-icon { font-size: 14px; line-height: 1; padding: 2px 0; flex-shrink: 0; }
.step-line { flex: 1; width: 1px; background: var(--border); margin: 4px 0; min-height: 8px; }
.step-row:last-child .step-line { display: none; }
.step-content { padding: 0 0 14px 8px; flex: 1; min-width: 0; }
.step-type { font-size: 11px; font-weight: 600; color: var(--text3); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 3px; }
.step-text { font-size: 14px; color: var(--text2); line-height: 1.5; word-break: break-word; }

/* Agent footer bars */
.agent-thinking-bar {
  height: 3px;
  border-radius: 2px;
  overflow: hidden;
  background: var(--bg3);
}
.thinking-shimmer {
  height: 100%;
  background: linear-gradient(90deg, transparent, var(--accent), transparent);
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
}
@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
.agent-done-bar {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: var(--green);
  font-weight: 500;
  border-top: 1px solid var(--border);
  padding-top: 12px;
}

/* ── HITL card ─────────────────────────────────────────────────────── */
.hitl-card {
  background: rgba(245,196,0,0.06);
  border: 1px solid rgba(245,196,0,0.3);
  border-radius: var(--r-sm);
  padding: 18px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.hitl-header { display: flex; align-items: center; gap: 8px; }
.hitl-icon { font-size: 18px; }
.hitl-title { font-size: 13px; font-weight: 600; color: var(--gold); }
.hitl-question { font-size: 15px; color: var(--text); line-height: 1.6; }
.hitl-context {
  font-size: 13px;
  color: var(--text2);
  background: rgba(255,255,255,0.04);
  border-radius: 6px;
  padding: 10px 12px;
  line-height: 1.5;
}
.hitl-options { display: flex; flex-direction: column; gap: 8px; }
.hitl-option {
  background: var(--bg3);
  border: 1px solid var(--border2);
  color: var(--text);
  padding: 12px 16px;
  border-radius: var(--r-sm);
  font-family: inherit;
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  text-align: left;
  transition: all 0.15s;
}
.hitl-option:hover { border-color: var(--gold); background: rgba(245,196,0,0.08); color: var(--gold); }
.hitl-option:disabled { opacity: 0.5; cursor: not-allowed; }
.hitl-input-row { display: flex; gap: 8px; }
.hitl-input {
  flex: 1;
  background: var(--bg3);
  border: 1px solid var(--border2);
  color: var(--text);
  padding: 12px 14px;
  border-radius: var(--r-sm);
  font-family: inherit;
  font-size: 14px;
  outline: none;
}
.hitl-input:focus { border-color: var(--gold); }
.hitl-input::placeholder { color: var(--text3); }
.hitl-send {
  background: var(--gold);
  color: #000;
  border: none;
  padding: 12px 18px;
  border-radius: var(--r-sm);
  font-family: inherit;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  white-space: nowrap;
  transition: opacity 0.15s;
}
.hitl-send:disabled { opacity: 0.4; cursor: not-allowed; }
.hitl-answered {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 10px 0;
  border-top: 1px solid var(--border);
}
.hitl-answered-icon { font-size: 16px; color: var(--green); flex-shrink: 0; margin-top: 1px; }
.hitl-answered-q { font-size: 13px; color: var(--text2); margin-bottom: 3px; }
.hitl-answered-a { font-size: 13px; color: var(--green); font-weight: 500; }

/* ── Inline sections ───────────────────────────────────────────────── */
.inline-section {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--r);
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}
.inline-section-title {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 15px;
  font-weight: 600;
  color: var(--text);
}
.section-icon { font-size: 17px; }
.section-count {
  background: var(--bg3);
  color: var(--text2);
  font-size: 12px;
  font-weight: 500;
  padding: 2px 8px;
  border-radius: 10px;
  margin-left: 2px;
}

/* ── Severity group ────────────────────────────────────────────────── */
.sev-group { display: flex; flex-direction: column; gap: 8px; }
.sev-group-label {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  font-weight: 600;
  text-transform: capitalize;
  padding: 4px 0;
}
.sev-group-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.sev-group-count {
  background: rgba(255,255,255,0.08);
  color: var(--text2);
  font-size: 11px;
  padding: 1px 7px;
  border-radius: 8px;
  margin-left: 2px;
}

/* ── Finding card ──────────────────────────────────────────────────── */
.finding-card {
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: var(--r-sm);
  overflow: hidden;
  cursor: pointer;
  transition: border-color 0.15s;
}
.finding-card:hover { border-color: var(--border2); }
.finding-header {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 14px;
}
.finding-sev-bar { width: 3px; height: 32px; border-radius: 2px; flex-shrink: 0; }
.finding-main { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4px; }
.finding-title { font-size: 14px; font-weight: 500; color: var(--text); }
.finding-meta-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.finding-badge {
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  padding: 2px 7px;
  border-radius: 4px;
  letter-spacing: 0.04em;
}
.finding-file { font-size: 12px; color: var(--text3); }
.finding-conf { font-size: 12px; color: var(--text3); }
.finding-toggle { font-size: 11px; color: var(--text3); flex-shrink: 0; }

.finding-detail {
  padding: 0 14px 14px;
  border-top: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding-top: 12px;
}
.finding-section { display: flex; flex-direction: column; gap: 6px; }
.finding-section-label { font-size: 12px; font-weight: 600; color: var(--text3); text-transform: uppercase; letter-spacing: 0.05em; }
.finding-section-text { font-size: 14px; color: var(--text2); line-height: 1.6; }
.finding-code {
  font-family: 'Menlo', 'Cascadia Code', monospace;
  font-size: 13px;
  background: rgba(0,0,0,0.3);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 12px;
  white-space: pre-wrap;
  word-break: break-all;
  color: #e0c97e;
  line-height: 1.5;
}

/* ── Report card ───────────────────────────────────────────────────── */
.report-card { display: flex; flex-direction: column; gap: 16px; }
.report-risk {
  display: inline-block;
  font-size: 12px;
  font-weight: 700;
  border: 2px solid;
  padding: 4px 12px;
  border-radius: 6px;
  letter-spacing: 0.08em;
}
.report-summary { font-size: 14px; color: var(--text2); line-height: 1.7; border-left: 3px solid var(--border2); padding-left: 14px; }
.report-recs-title { font-size: 13px; font-weight: 600; color: var(--text3); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; }
.report-rec-item { display: flex; gap: 14px; align-items: start; padding: 10px 0; border-bottom: 1px solid var(--border); }
.rec-num { font-size: 22px; font-weight: 700; color: var(--border2); min-width: 24px; line-height: 1.2; }
.rec-action { font-size: 14px; font-weight: 500; color: var(--text); margin-bottom: 3px; }
.rec-rationale { font-size: 13px; color: var(--text2); line-height: 1.5; }
.report-conclusion { font-size: 13px; color: var(--text2); line-height: 1.7; }
.report-loading { font-size: 13px; color: var(--text3); padding: 8px 0; }
.btn-load-report {
  background: var(--bg3);
  border: 1px solid var(--border2);
  color: var(--text2);
  padding: 10px 18px;
  border-radius: var(--r-sm);
  font-family: inherit;
  font-size: 14px;
  cursor: pointer;
  transition: all 0.15s;
  align-self: flex-start;
}
.btn-load-report:hover { border-color: var(--accent); color: var(--text); }

/* CWE and OWASP badges */
.finding-cwe {
  font-size: 10px;
  font-weight: 700;
  background: rgba(108,99,255,0.15);
  color: #a78bfa;
  padding: 2px 6px;
  border-radius: 4px;
  letter-spacing: 0.04em;
  font-family: 'Menlo', monospace;
}
.finding-owasp {
  font-size: 10px;
  font-weight: 600;
  background: rgba(249,115,22,0.15);
  color: #fb923c;
  padding: 2px 6px;
  border-radius: 4px;
  letter-spacing: 0.04em;
}
