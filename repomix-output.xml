# HoneySentinel-OS Security Policy
# Version 2.0 — with CWE mappings

version: "2.0"

context:
  project_name: "My Project"
  project_type: "web_application"
  language_stack:
    - python
    - javascript
  framework: "fastapi"
  authentication_type: "jwt"
  data_sensitivity: "high"
  deployment_target: "cloud"
  has_database: true
  database_type: "postgresql"
  exposes_public_api: true
  handles_pii: true

agents:
  # Set to 0.95 — guarantees HITL triggers for demo
  # Every finding below 95% confidence will pause and ask the human
  confidence_threshold: 0.95
  max_iterations: 50
  max_findings: 50
  require_fp_reasoning: true

rules:

  - id: HARDCODED_SECRET
    enabled: true
    severity: critical
    category: secrets
    cwe_id: "CWE-798"
    cwe_name: "Use of Hard-coded Credentials"
    owasp: "A07:2021"
    title: "Hardcoded secret or credential"
    description: >
      API keys, passwords, tokens, or private keys hardcoded directly in source
      files rather than loaded from environment variables or a secrets manager.
    pattern_hints:
      - "hardcoded password"
      - "api key in source"
      - "secret = "
      - "private key literal"
      - "token hardcoded"
    languages: [python, javascript, typescript, java, go]
    false_positive_signals:
      - "test fixture"
      - "mock data"
      - "example key"
      - "placeholder"
      - "YOUR_KEY_HERE"

